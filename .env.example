#db
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=your_host# If u launch with docker -> db_host must be "db"
DB_NAME=your_db_name
DB_PORT=your_port# Default -> 5432

#app
BASE_URL=your_base_url# Local host example -> "http://127.0.0.1:8000/"

#tools
MODE=# In .test.env -> TEST.
     # In .env -> PROD

